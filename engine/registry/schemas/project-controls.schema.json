{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["selected"],
  "properties": {
    "selected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "applies_because"],
        "properties": {
          "id": {"type": "string", "pattern": "^CTRL-[A-Z0-9]{2,8}-\\d{3}$"},
          "applies_because": {"type": "string", "minLength": 5},
          "owner": {"type": "string"},
          "exemption": {"type": "string"}
        }
      }
    }
  }
}
