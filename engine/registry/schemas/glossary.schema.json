{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["terms"],
  "properties": {
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "properties": {
          "term": {"type": "string", "minLength": 2},
          "definition": {"type": "string", "minLength": 5},
          "source": {"type": "string"},
          "first_introduced_in": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  }
}
