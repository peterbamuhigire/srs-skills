{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["label", "created_on", "entries"],
  "properties": {
    "label": {"type": "string", "minLength": 1},
    "created_on": {"type": "string", "format": "date"},
    "current": {"type": "boolean"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sha256"],
        "properties": {
          "id": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
